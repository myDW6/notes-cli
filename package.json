{
  "name": "@shaodw/notes-cli",
  "version": "1.0.1",
  "description": "A simple CLI for managing local notes, demonstrating CLI design patterns",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "notes": "./dist/index.js"
  },
  "files": [
    "dist/",
