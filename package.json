{
  "name": "notes-cli",
  "version": "1.0.0",
  "description": "A simple CLI for managing local notes, demonstrating CLI design patterns",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "notes": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
